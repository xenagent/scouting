@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>404 - Sayfa Bulunamadı</PageTitle>
        <LayoutView Layout="@typeof(Components.Layout.MainLayout)">
            <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
                <span class="text-8xl font-display text-pitch-600">404</span>
                <p class="text-scout-400 mt-4">Aradığınız sayfa bulunamadı.</p>
                <a href="/" class="btn-primary mt-6">Ana Sayfaya Dön</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
