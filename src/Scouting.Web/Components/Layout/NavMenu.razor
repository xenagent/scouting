@inject NavigationManager Nav

<header class="sticky top-0 z-50 border-b border-scout-800/80 bg-scout-950/80 backdrop-blur-sm">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-6">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-1.5 shrink-0">
            <svg class="w-6 h-6 text-pitch-500" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 2 L12 22 M2 12 L22 12" stroke="currentColor" stroke-width="1" opacity="0.4"/>
                <circle cx="12" cy="12" r="3" fill="currentColor"/>
            </svg>
            <span class="font-display text-xl text-white tracking-wider">SCOUT</span>
        </a>

        <!-- Nav Links -->
        <div class="hidden sm:flex items-center gap-6">
            <a href="/players" class="@LinkClass("/players")">Oyuncular</a>
            <a href="/scouters" class="@LinkClass("/scouters")">Scoutlar</a>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-3">
            <a href="/suggest" class="btn-primary text-xs px-3 py-2">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                Öneri Ekle
            </a>
            <a href="/login" class="btn-secondary text-xs px-3 py-2">Giriş</a>
        </div>

    </nav>
</header>

@code {
    private string LinkClass(string path)
    {
        var current = new Uri(Nav.Uri).AbsolutePath;
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase)
            ? "nav-link-active"
            : "nav-link";
    }
}
