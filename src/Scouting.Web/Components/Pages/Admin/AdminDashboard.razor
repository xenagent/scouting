@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IPlayerService PlayerService
@rendermode InteractiveServer

<PageTitle>Admin — Scout</PageTitle>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8">
        <h1 class="font-display text-4xl text-white mb-2">ADMİN PANELİ</h1>
        <p class="text-scout-400">Bekleyen oyuncu önerilerini incele ve değerlendir</p>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-scout-800 mb-8">
        <button @onclick='() => _activeTab = "pending"'
                class="@TabClass("pending") px-4 py-2.5 text-sm font-medium transition-colors relative">
            Bekleyenler
            @if (_pendingPlayers?.Count > 0)
            {
                <span class="ml-2 badge-pending">@_pendingPlayers.Count</span>
            }
        </button>
    </div>

    @if (_loading)
    {
        <div class="space-y-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="card animate-pulse">
                    <div class="h-4 bg-scout-800 rounded w-1/4 mb-3"></div>
                    <div class="h-3 bg-scout-800 rounded w-1/3 mb-6"></div>
                    <div class="h-16 bg-scout-800 rounded"></div>
                </div>
            }
        </div>
    }
    else if (_pendingPlayers?.Count == 0)
    {
        <div class="card text-center py-16 text-scout-500">
            <p class="text-4xl mb-4">✓</p>
            <p>Tüm öneriler incelendi!</p>
        </div>
    }
    else
    {
        <div class="space-y-6">
            @foreach (var player in _pendingPlayers!)
            {
                <div class="card @(_processingId == player.Id ? "opacity-50" : "")">
                    <!-- Header -->
                    <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <span class="badge-position">@player.Position</span>
                                <span class="badge bg-scout-800 text-scout-400">@player.Age yaş</span>
                                @if (player.AIScore.HasValue)
                                {
                                    <span class="ai-score">AI @player.AIScore.Value.ToString("0.0")</span>
                                }
                            </div>
                            <h3 class="text-xl font-bold text-white">@player.Name</h3>
                            <p class="text-scout-400 text-sm">@player.Team · @player.League · @player.Country</p>
                        </div>
                        <div class="text-right text-xs text-scout-600">
                            <p>@@player.SuggestedByUsername</p>
                            <p>@player.SubmittedAt.ToString("dd MMM yyyy")</p>
                        </div>
                    </div>

                    <!-- AI Summary -->
                    @if (!string.IsNullOrEmpty(player.AISummary))
                    {
                        <div class="bg-violet-950/30 border border-violet-800/40 rounded-lg p-3 mb-4">
                            <p class="text-xs text-violet-400 font-medium mb-1">AI Özeti</p>
                            <p class="text-sm text-violet-200">@player.AISummary</p>
                        </div>
                    }

                    <!-- Analysis Content -->
                    <div class="bg-scout-800/40 rounded-lg p-4 mb-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs text-scout-500 font-medium uppercase tracking-wide">Analiz İçeriği</p>
                            <a href="@player.VideoUrl" target="_blank" class="text-xs text-pitch-400 hover:text-pitch-300 flex items-center gap-1">
                                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7L8 5z"/></svg>
                                Video
                            </a>
                        </div>
                        <p class="text-sm text-scout-300 leading-relaxed max-h-32 overflow-y-auto">@player.AnalysisContent</p>
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-wrap items-center gap-3">
                        <button @onclick="() => Approve(player.Id)" class="btn-primary text-sm">
                            ✓ Onayla
                        </button>
                        <div class="flex-1 flex gap-2">
                            <input @bind="_rejectReasons[player.Id]"
                                   placeholder="Red gerekçesi..."
                                   class="input text-sm flex-1" />
                            <button @onclick="() => Reject(player.Id)" class="btn-danger text-sm">
                                ✕ Reddet
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<PendingPlayerVm>? _pendingPlayers;
    private bool _loading = true;
    private string _activeTab = "pending";
    private Guid? _processingId;
    private Dictionary<Guid, string> _rejectReasons = new();

    protected override async Task OnInitializedAsync() => await LoadPending();

    private async Task LoadPending()
    {
        _loading = true;
        var result = await PlayerService.GetPendingAsync(1, 50);
        _pendingPlayers = result.Data;
        _loading = false;
    }

    private async Task Approve(Guid playerId)
    {
        _processingId = playerId;
        await PlayerService.ApproveAsync(playerId);
        _pendingPlayers?.RemoveAll(p => p.Id == playerId);
        _processingId = null;
    }

    private async Task Reject(Guid playerId)
    {
        var reason = _rejectReasons.GetValueOrDefault(playerId);
        if (string.IsNullOrWhiteSpace(reason)) return;

        _processingId = playerId;
        await PlayerService.RejectAsync(playerId, reason);
        _pendingPlayers?.RemoveAll(p => p.Id == playerId);
        _rejectReasons.Remove(playerId);
        _processingId = null;
    }

    private string TabClass(string tab) => _activeTab == tab
        ? "text-white border-b-2 border-pitch-500"
        : "text-scout-400 hover:text-white";
}
