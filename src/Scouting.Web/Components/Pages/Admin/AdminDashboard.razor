@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IPlayerService PlayerService
@inject IAnalysisService AnalysisService
@inject IFileService FileService
@rendermode InteractiveServer

<PageTitle>Admin — Scout</PageTitle>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-8">
        <h1 class="font-display text-4xl text-white mb-2">ADMİN PANELİ</h1>
        <p class="text-scout-400">Bekleyen oyuncu önerilerini ve analizleri incele</p>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-scout-800 mb-8 gap-1">
        <button @onclick='() => _activeTab = "players"'
                class="@TabClass("players") px-4 py-2.5 text-sm font-medium transition-colors relative">
            Oyuncular
            @if (_pendingPlayers?.Count > 0)
            {
                <span class="ml-2 badge-pending">@_pendingPlayers.Count</span>
            }
        </button>
        <button @onclick='() => SwitchTab("analyses")'
                class="@TabClass("analyses") px-4 py-2.5 text-sm font-medium transition-colors relative">
            Analizler
            @if (_pendingAnalyses?.Count > 0)
            {
                <span class="ml-2 badge-pending">@_pendingAnalyses.Count</span>
            }
        </button>
    </div>

    <!-- ── OYUNCULAR TAB ── -->
    @if (_activeTab == "players")
    {
        @if (_loading)
        {
            <div class="space-y-4">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="card animate-pulse">
                        <div class="h-4 bg-scout-800 rounded w-1/4 mb-3"></div>
                        <div class="h-3 bg-scout-800 rounded w-1/3 mb-6"></div>
                        <div class="h-16 bg-scout-800 rounded"></div>
                    </div>
                }
            </div>
        }
        else if (_pendingPlayers?.Count == 0)
        {
            <div class="card text-center py-16 text-scout-500">
                <p class="text-4xl mb-4">✓</p>
                <p>Tüm oyuncu önerileri incelendi!</p>
            </div>
        }
        else
        {
            <div class="space-y-6">
                @foreach (var player in _pendingPlayers!)
                {
                    <div class="card @(_processingPlayerId == player.Id ? "opacity-50" : "")">
                        <!-- Header -->
                        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="badge-position">@player.Position</span>
                                    <span class="badge bg-scout-800 text-scout-400">@player.Age yaş</span>
                                    @if (player.AIScore.HasValue)
                                    {
                                        <span class="ai-score">AI @player.AIScore.Value.ToString("0.0")</span>
                                    }
                                </div>
                                <h3 class="text-xl font-bold text-white">@player.Name</h3>
                                <p class="text-scout-400 text-sm">@player.Team · @player.League · @player.Country</p>
                            </div>
                            <div class="text-right text-xs text-scout-600">
                                <p>@@player.SuggestedByUsername</p>
                                <p>@player.SubmittedAt.ToString("dd MMM yyyy")</p>
                            </div>
                        </div>

                        <!-- Player Image Upload -->
                        <div class="mb-4">
                            @if (_playerImageUrls.TryGetValue(player.Id, out var imgUrl) && !string.IsNullOrEmpty(imgUrl))
                            {
                                <div class="flex items-center gap-3">
                                    <img src="@imgUrl" alt="@player.Name" class="w-16 h-16 rounded-lg object-cover border border-scout-700" />
                                    <div class="flex-1">
                                        <p class="text-xs text-pitch-400 truncate">@imgUrl</p>
                                    </div>
                                    <button type="button" @onclick="() => _playerImageUrls.Remove(player.Id)"
                                            class="text-xs text-red-400 hover:text-red-300">Kaldır</button>
                                </div>
                            }
                            else
                            {
                                <label class="flex items-center gap-2 border border-dashed border-scout-700 rounded-lg p-2.5 cursor-pointer hover:border-pitch-600 transition-colors w-fit @(_uploadingPlayerId == player.Id ? "opacity-50 pointer-events-none" : "")">
                                    @if (_uploadingPlayerId == player.Id)
                                    {
                                        <span class="text-xs text-scout-400">Yükleniyor...</span>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4 text-scout-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                        <span class="text-xs text-scout-400">Oyuncu fotoğrafı yükle</span>
                                    }
                                    <InputFile OnChange="e => OnPlayerImageSelected(e, player.Id)" accept=".jpg,.jpeg,.png,.webp" class="hidden" />
                                </label>
                            }
                        </div>

                        <!-- AI Summary -->
                        @if (!string.IsNullOrEmpty(player.AISummary))
                        {
                            <div class="bg-violet-950/30 border border-violet-800/40 rounded-lg p-3 mb-4">
                                <p class="text-xs text-violet-400 font-medium mb-1">AI Özeti</p>
                                <p class="text-sm text-violet-200">@player.AISummary</p>
                            </div>
                        }

                        <!-- Analysis Content -->
                        <div class="bg-scout-800/40 rounded-lg p-4 mb-4">
                            <div class="flex items-center justify-between mb-2">
                                <p class="text-xs text-scout-500 font-medium uppercase tracking-wide">Analiz İçeriği</p>
                                @if (!string.IsNullOrEmpty(player.VideoUrl))
                                {
                                    <a href="@player.VideoUrl" target="_blank" class="text-xs text-pitch-400 hover:text-pitch-300 flex items-center gap-1">
                                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7L8 5z"/></svg>
                                        Video
                                    </a>
                                }
                            </div>
                            <p class="text-sm text-scout-300 leading-relaxed max-h-32 overflow-y-auto">@player.AnalysisContent</p>
                        </div>

                        <!-- Actions -->
                        <div class="flex flex-wrap items-center gap-3">
                            <button @onclick="() => ApprovePlayer(player.Id)" class="btn-primary text-sm">
                                ✓ Onayla
                            </button>
                            <div class="flex-1 flex gap-2">
                                <input @bind="_playerRejectReasons[player.Id]"
                                       placeholder="Red gerekçesi..."
                                       class="input text-sm flex-1" />
                                <button @onclick="() => RejectPlayer(player.Id)" class="btn-danger text-sm">
                                    ✕ Reddet
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

    <!-- ── ANALİZLER TAB ── -->
    @if (_activeTab == "analyses")
    {
        @if (_analysesLoading)
        {
            <div class="space-y-4">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="card animate-pulse">
                        <div class="h-4 bg-scout-800 rounded w-1/4 mb-3"></div>
                        <div class="h-16 bg-scout-800 rounded"></div>
                    </div>
                }
            </div>
        }
        else if (_pendingAnalyses?.Count == 0)
        {
            <div class="card text-center py-16 text-scout-500">
                <p class="text-4xl mb-4">✓</p>
                <p>Tüm analizler incelendi!</p>
            </div>
        }
        else
        {
            <div class="space-y-5">
                @foreach (var analysis in _pendingAnalyses!)
                {
                    <div class="card @(_processingAnalysisId == analysis.Id ? "opacity-50" : "")">
                        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                            <div>
                                <a href="/players/@analysis.PlayerSlug" class="text-lg font-bold text-white hover:text-pitch-400 transition-colors">
                                    @analysis.PlayerName
                                </a>
                                <p class="text-xs text-scout-500 mt-0.5">
                                    <span class="text-pitch-500">@@analysis.SuggestedByUsername</span>
                                    tarafından · @analysis.SubmittedAt.ToString("dd MMM yyyy")
                                </p>
                            </div>
                            @if (!string.IsNullOrEmpty(analysis.VideoUrl))
                            {
                                <a href="@analysis.VideoUrl" target="_blank" class="text-xs text-pitch-400 hover:text-pitch-300 flex items-center gap-1 shrink-0">
                                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7L8 5z"/></svg>
                                    Video
                                </a>
                            }
                        </div>

                        <div class="bg-scout-800/40 rounded-lg p-4 mb-4">
                            <p class="text-sm text-scout-300 leading-relaxed max-h-32 overflow-y-auto">@analysis.ContentPreview</p>
                        </div>

                        <div class="flex flex-wrap items-center gap-3">
                            <button @onclick="() => ApproveAnalysis(analysis.Id)" class="btn-primary text-sm">
                                ✓ Onayla
                            </button>
                            <div class="flex-1 flex gap-2">
                                <input @bind="_analysisRejectReasons[analysis.Id]"
                                       placeholder="Red gerekçesi..."
                                       class="input text-sm flex-1" />
                                <button @onclick="() => RejectAnalysis(analysis.Id)" class="btn-danger text-sm">
                                    ✕ Reddet
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }

</div>

@code {
    private List<PendingPlayerVm>? _pendingPlayers;
    private List<PendingAnalysisVm>? _pendingAnalyses;
    private bool _loading = true;
    private bool _analysesLoading;
    private string _activeTab = "players";
    private Guid? _processingPlayerId;
    private Guid? _processingAnalysisId;
    private Guid? _uploadingPlayerId;
    private Dictionary<Guid, string> _playerRejectReasons = new();
    private Dictionary<Guid, string> _analysisRejectReasons = new();
    private Dictionary<Guid, string> _playerImageUrls = new();

    protected override async Task OnInitializedAsync() => await LoadPlayers();

    private async Task LoadPlayers()
    {
        _loading = true;
        var result = await PlayerService.GetPendingAsync(1, 50);
        _pendingPlayers = result.Data;
        _loading = false;
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        if (tab == "analyses" && _pendingAnalyses is null)
        {
            _analysesLoading = true;
            var result = await AnalysisService.GetPendingAsync(1, 50);
            _pendingAnalyses = result.Data;
            _analysesLoading = false;
        }
    }

    private async Task OnPlayerImageSelected(InputFileChangeEventArgs e, Guid playerId)
    {
        _uploadingPlayerId = playerId;
        var result = await FileService.UploadPlayerImageAsync(e.File);
        if (result.IsSuccess)
        {
            _playerImageUrls[playerId] = result.Data!;
            await PlayerService.SetPlayerImageAsync(playerId, result.Data!);
        }
        _uploadingPlayerId = null;
    }

    private async Task ApprovePlayer(Guid playerId)
    {
        _processingPlayerId = playerId;
        await PlayerService.ApproveAsync(playerId);
        _pendingPlayers?.RemoveAll(p => p.Id == playerId);
        _playerImageUrls.Remove(playerId);
        _processingPlayerId = null;
    }

    private async Task RejectPlayer(Guid playerId)
    {
        var reason = _playerRejectReasons.GetValueOrDefault(playerId);
        if (string.IsNullOrWhiteSpace(reason)) return;

        _processingPlayerId = playerId;
        await PlayerService.RejectAsync(playerId, reason);
        _pendingPlayers?.RemoveAll(p => p.Id == playerId);
        _playerRejectReasons.Remove(playerId);
        _playerImageUrls.Remove(playerId);
        _processingPlayerId = null;
    }

    private async Task ApproveAnalysis(Guid analysisId)
    {
        _processingAnalysisId = analysisId;
        await AnalysisService.ApproveAsync(analysisId);
        _pendingAnalyses?.RemoveAll(a => a.Id == analysisId);
        _processingAnalysisId = null;
    }

    private async Task RejectAnalysis(Guid analysisId)
    {
        var reason = _analysisRejectReasons.GetValueOrDefault(analysisId);
        if (string.IsNullOrWhiteSpace(reason)) return;

        _processingAnalysisId = analysisId;
        await AnalysisService.RejectAsync(analysisId, reason);
        _pendingAnalyses?.RemoveAll(a => a.Id == analysisId);
        _analysisRejectReasons.Remove(analysisId);
        _processingAnalysisId = null;
    }

    private string TabClass(string tab) => _activeTab == tab
        ? "text-white border-b-2 border-pitch-500"
        : "text-scout-400 hover:text-white";
}
