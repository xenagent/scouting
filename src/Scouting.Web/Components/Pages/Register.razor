@page "/register"

<PageTitle>Kayıt Ol — Scout</PageTitle>

<div class="max-w-sm mx-auto px-4 py-16">

    <div class="text-center mb-8">
        <span class="font-display text-3xl text-white">SCOUT</span>
        <p class="text-scout-400 mt-2">Hesap oluşturun</p>
    </div>

    <div class="card">
        <form method="post" action="/account/register" class="space-y-4">
            <AntiforgeryToken />
            <div>
                <label class="label">Kullanıcı Adı</label>
                <input name="username" type="text" placeholder="scout_ahmet" class="input" required />
                <p class="text-xs text-scout-600 mt-1">Harf, rakam ve alt çizgi. 3-32 karakter.</p>
            </div>
            <div>
                <label class="label">E-posta</label>
                <input name="email" type="email" placeholder="ornek@email.com" class="input" required />
            </div>
            <div>
                <label class="label">Şifre</label>
                <input name="password" type="password" placeholder="Min. 6 karakter" class="input" required minlength="6" />
            </div>

            <button type="submit" class="btn-primary w-full">Kayıt Ol</button>
        </form>

        <p class="text-center text-sm text-scout-500 mt-4">
            Zaten hesabın var mı?
            <a href="/login" class="text-pitch-400 hover:text-pitch-300">Giriş yap</a>
        </p>
    </div>
</div>
