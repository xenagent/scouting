@page "/players/{Slug}"
@inject IPlayerService PlayerService
@inject IVoteService VoteService
@inject IAnalysisLikeService LikeService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@using System.Security.Claims
@rendermode InteractiveServer

@if (_loading)
{
    <PageTitle>Yükleniyor...</PageTitle>
    <div class="max-w-5xl mx-auto px-4 py-10 animate-pulse space-y-4">
        <div class="h-8 bg-scout-800 rounded w-1/3" />
        <div class="h-4 bg-scout-800 rounded w-1/4" />
    </div>
}
else if (_player is null)
{
    <PageTitle>Bulunamadı — Scout</PageTitle>
    <div class="flex flex-col items-center justify-center min-h-[60vh]">
        <p class="text-6xl mb-4">⚽</p>
        <h1 class="text-xl text-white font-bold mb-4">Oyuncu Bulunamadı</h1>
        <a href="/players" class="btn-secondary">Oyunculara Dön</a>
    </div>
}
else
{
    <PageTitle>@_player.Name — @_player.Position | Scout</PageTitle>
    <HeadContent>
        <meta name="description" content="@_player.Name: @_player.Age yaşında @_player.Position, @_player.Team (@_player.League). @_player.Analyses.Count analiz mevcut." />
        <meta property="og:title" content="@_player.Name — @_player.Position | Scout" />
        <meta property="og:description" content="@_player.Age yaş | @_player.Team | @_player.League | @_player.Country" />
        @if (!string.IsNullOrEmpty(_player.ImageUrl))
        {
            <meta property="og:image" content="@_player.ImageUrl" />
        }
        <link rel="canonical" href="@Nav.BaseUri.TrimEnd('/')/players/@Slug" />
    </HeadContent>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

        <!-- Header card -->
        <div class="card mb-8">
            <div class="flex flex-col sm:flex-row gap-6">
                <div class="w-28 h-28 sm:w-36 sm:h-36 rounded-xl bg-scout-800 border border-scout-700 flex items-center justify-center shrink-0 overflow-hidden">
                    @if (!string.IsNullOrEmpty(_player.ImageUrl))
                    {
                        <img src="@_player.ImageUrl" alt="@_player.Name" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="font-display text-5xl text-scout-600">@_player.Name[0]</span>
                    }
                </div>

                <div class="flex-1">
                    <div class="flex flex-wrap gap-2 mb-2">
                        <span class="badge-position">@_player.Position</span>
                        <span class="badge bg-scout-800 text-scout-400">@_player.Age yaş</span>
                        <span class="badge bg-scout-800 text-scout-400">@_player.Country</span>
                    </div>
                    <h1 class="font-display text-4xl sm:text-5xl text-white tracking-tight mb-1">
                        @_player.Name.ToUpperInvariant()
                    </h1>
                    <p class="text-scout-400 text-lg">@_player.Team <span class="text-scout-600">·</span> @_player.League</p>

                    <div class="flex flex-wrap items-center gap-4 mt-5 pt-5 border-t border-scout-800">
                        @if (_isLoggedIn)
                        {
                            <div class="flex items-center gap-2">
                                <button @onclick='() => Vote("Up")'
                                        class="@(_userVote == "Up" ? "vote-up-active" : "vote-up")">
                                    ▲ @_player.UpvoteCount
                                </button>
                                <button @onclick='() => Vote("Down")'
                                        class="@(_userVote == "Down" ? "vote-down-active" : "vote-down")">
                                    ▼ @_player.DownvoteCount
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="flex items-center gap-3 text-scout-500 text-sm">
                                <span>▲ @_player.UpvoteCount</span>
                                <span>▼ @_player.DownvoteCount</span>
                                <a href="/login" class="text-pitch-500 hover:text-pitch-400">Oy vermek için giriş yap</a>
                            </div>
                        }
                        <div class="text-scout-400 text-sm">
                            Skor: <span class="text-white font-bold">@_player.Score</span>
                        </div>
                        <div class="text-scout-400 text-sm">
                            <a href="/scouters/@_player.SuggestedByUsername" class="hover:text-pitch-400 transition-colors">
                                @("@" + _player.SuggestedByUsername)
                            </a> önerdi
                        </div>
                        @if (_isLoggedIn)
                        {
                            <a href="/analysis/new?slug=@Slug" class="text-xs text-pitch-400 hover:text-pitch-300 ml-auto">
                                + Analiz Yaz
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Transfermarkt Panel -->
        @if (_player.MarketValue.HasValue || _player.SeasonStats.Count > 0 || _isAdmin)
        {
            <div class="card mb-8 border border-scout-800">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-3">
                        <span class="text-sm font-semibold text-scout-300 uppercase tracking-wider">Transfermarkt Verileri</span>
                        @if (_player.LastTransfermarktSync.HasValue)
                        {
                            <span class="text-xs text-scout-600">Son sync: @_player.LastTransfermarktSync.Value.ToString("dd MMM yyyy HH:mm")</span>
                        }
                    </div>
                    @if (_isAdmin && !string.IsNullOrEmpty(_player.TransfermarktUrl))
                    {
                        <button @onclick="SyncFromTm" disabled="@_syncing"
                                class="flex items-center gap-2 text-xs px-3 py-1.5 rounded-lg border border-pitch-700 text-pitch-400 hover:bg-pitch-950 hover:text-pitch-300 transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                            @if (_syncing)
                            {
                                <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                                <span>Çekiliyor...</span>
                            }
                            else
                            {
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                                </svg>
                                <span>TM'den Sync Et</span>
                            }
                        </button>
                    }
                </div>

                @if (_syncError is not null)
                {
                    <div class="text-xs text-red-400 mb-3">@_syncError</div>
                }
                @if (_syncSuccess)
                {
                    <div class="text-xs text-pitch-400 mb-3">Veriler güncellendi.</div>
                }

                <!-- Market value -->
                @if (_player.MarketValue.HasValue)
                {
                    <div class="flex items-center gap-4 mb-5">
                        <div>
                            <p class="text-xs text-scout-500 mb-0.5">Piyasa Değeri</p>
                            <p class="text-xl font-bold text-white">€@_player.MarketValue.Value.ToString("0.##")m</p>
                        </div>
                        @if (_player.PreviousMarketValue.HasValue)
                        {
                            var diff = _player.MarketValue.Value - _player.PreviousMarketValue.Value;
                            var isUp = diff > 0;
                            <div class="flex items-center gap-1 @(isUp ? "text-pitch-400" : "text-red-400") text-sm">
                                <span>@(isUp ? "▲" : "▼")</span>
                                <span>€@Math.Abs(diff).ToString("0.##")m</span>
                                <span class="text-scout-600 text-xs">(önceki sync)</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_player.TransfermarktUrl))
                        {
                            <a href="@_player.TransfermarktUrl" target="_blank" rel="noopener noreferrer"
                               class="text-xs text-scout-500 hover:text-scout-300 ml-auto">
                                Transfermarkt'ta Aç ↗
                            </a>
                        }
                    </div>
                }

                <!-- Season stats table -->
                @if (_player.SeasonStats.Count > 0)
                {
                    <div>
                        <p class="text-xs text-scout-500 uppercase tracking-wider mb-2">Sezon İstatistikleri</p>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="text-xs text-scout-500 border-b border-scout-800">
                                        <th class="text-left py-2 pr-4">Sezon</th>
                                        <th class="text-left py-2 pr-4 hidden sm:table-cell">Lig / Kupa</th>
                                        <th class="text-center py-2 px-3">Maç</th>
                                        <th class="text-center py-2 px-3">Dk</th>
                                        <th class="text-center py-2 px-3">Gol</th>
                                        <th class="text-center py-2 px-3">Asist</th>
                                        <th class="text-center py-2 px-3">G+A</th>
                                        <th class="text-center py-2 px-3 hidden md:table-cell" title="90 dakikada gol">Gol/90</th>
                                        <th class="text-center py-2 px-3 hidden md:table-cell" title="90 dakikada asist">Ast/90</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in _player.SeasonStats)
                                    {
                                        <tr class="border-b border-scout-900 hover:bg-scout-900/30">
                                            <td class="py-2 pr-4 text-white font-medium whitespace-nowrap">@s.Season</td>
                                            <td class="py-2 pr-4 text-scout-400 text-xs hidden sm:table-cell">@(s.Competition ?? "—")</td>
                                            <td class="py-2 px-3 text-center text-scout-300">@s.Matches</td>
                                            <td class="py-2 px-3 text-center text-scout-400 text-xs">@(s.MinutesPlayed > 0 ? s.MinutesPlayed + "'" : "—")</td>
                                            <td class="py-2 px-3 text-center @(s.Goals > 0 ? "text-pitch-400 font-semibold" : "text-scout-500")">@s.Goals</td>
                                            <td class="py-2 px-3 text-center @(s.Assists > 0 ? "text-violet-400 font-semibold" : "text-scout-500")">@s.Assists</td>
                                            <td class="py-2 px-3 text-center text-scout-300">@(s.Goals + s.Assists)</td>
                                            <td class="py-2 px-3 text-center text-scout-400 text-xs hidden md:table-cell">@(s.GoalsPer90?.ToString("0.00") ?? "—")</td>
                                            <td class="py-2 px-3 text-center text-scout-400 text-xs hidden md:table-cell">@(s.AssistsPer90?.ToString("0.00") ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @if (!_player.MarketValue.HasValue && _player.SeasonStats.Count == 0 && _isAdmin)
                {
                    <p class="text-sm text-scout-600">
                        @if (!string.IsNullOrEmpty(_player.TransfermarktUrl))
                        {
                            <span>TM ID kayıtlı ama henüz sync edilmemiş. "TM'den Sync Et" butonunu kullanabilirsin.</span>
                        }
                        else
                        {
                            <span>Bu oyuncuya henüz Transfermarkt ID'si eklenmemiş.</span>
                        }
                    </p>
                }
            </div>
        }

        <!-- Analyses -->
        <h2 class="section-title mb-6">
            <span class="text-violet-500 mr-2">✦</span>Analizler
            <span class="text-scout-600 text-base font-normal ml-2">(@_player.Analyses.Count)</span>
        </h2>

        @if (_player.Analyses.Count == 0)
        {
            <div class="card text-center py-10 text-scout-500">
                <p class="mb-3">Henüz onaylı analiz yok.</p>
                @if (_isLoggedIn)
                {
                    <a href="/analysis/new?slug=@Slug" class="btn-primary text-sm">İlk analizi sen yaz</a>
                }
            </div>
        }
        else
        {
            <div class="space-y-5">
                @foreach (var a in _player.Analyses)
                {
                    <div class="card @(a.IsFlaggedAsDuplicate ? "border border-yellow-800/40" : "")">
                        <!-- Scout header -->
                        <div class="flex items-center justify-between mb-4">
                            <a href="/scouters/@a.ScoutUsername" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
                                <div class="w-8 h-8 rounded-full bg-pitch-950 border border-pitch-800 flex items-center justify-center">
                                    <span class="text-pitch-500 font-bold text-xs">@a.ScoutUsername[0..1].ToUpper()</span>
                                </div>
                                <div>
                                    <span class="text-sm font-semibold text-white">@@@a.ScoutUsername</span>
                                    <span class="@a.ScoutLevel.BadgeClass() ml-2 text-xs">@a.ScoutLevel.DisplayName()</span>
                                </div>
                            </a>
                            <div class="flex items-center gap-2">
                                @if (a.IsFlaggedAsDuplicate)
                                {
                                    <span class="badge bg-yellow-900/40 text-yellow-500 text-xs">⚠ Benzer</span>
                                }
                                @if (a.AIScore.HasValue)
                                {
                                    <span class="ai-score" title="Kalite Skoru">@a.AIScore.Value.ToString("0.0")/10</span>
                                }
                                @if (a.FilledSectionsCount > 0)
                                {
                                    <span class="text-xs text-scout-600" title="Doldurulmuş bölüm sayısı">@a.FilledSectionsCount/5 bölüm</span>
                                }
                                <span class="text-xs text-scout-600">@a.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>

                        <!-- AI Summary -->
                        @if (!string.IsNullOrEmpty(a.AISummary))
                        {
                            <div class="bg-violet-950/30 border border-violet-800/40 rounded-lg p-3 mb-4">
                                <p class="text-xs text-violet-400 font-medium mb-1">AI Özeti</p>
                                <p class="text-sm text-violet-200">@a.AISummary</p>
                            </div>
                        }

                        <!-- General content -->
                        <p class="text-scout-300 leading-relaxed text-sm whitespace-pre-line mb-4">@a.Content</p>

                        <!-- Optional sections -->
                        @if (a.FilledSectionsCount > 0)
                        {
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
                                @if (!string.IsNullOrEmpty(a.TechnicalContent))
                                {
                                    <AnalysisSection Label="Teknik" Icon="⚙" Content="@a.TechnicalContent" />
                                }
                                @if (!string.IsNullOrEmpty(a.TacticalContent))
                                {
                                    <AnalysisSection Label="Taktiksel" Icon="🗺" Content="@a.TacticalContent" />
                                }
                                @if (!string.IsNullOrEmpty(a.PhysicalContent))
                                {
                                    <AnalysisSection Label="Fiziksel" Icon="💪" Content="@a.PhysicalContent" />
                                }
                                @if (!string.IsNullOrEmpty(a.StrengthsContent))
                                {
                                    <AnalysisSection Label="Güçlü Yönler" Icon="✦" Content="@a.StrengthsContent" />
                                }
                                @if (!string.IsNullOrEmpty(a.WeaknessesContent))
                                {
                                    <AnalysisSection Label="Geliştirmesi Gerekenler" Icon="↗" Content="@a.WeaknessesContent" />
                                }
                            </div>
                        }

                        <!-- Footer: Video + Share + Like -->
                        <div class="flex items-center justify-between gap-3 flex-wrap">
                            <a href="@a.VideoUrl" target="_blank" rel="noopener noreferrer"
                               class="inline-flex items-center gap-2 text-sm text-pitch-400 hover:text-pitch-300 transition-colors">
                                ▶ Videoyu İzle
                            </a>

                            <div class="flex items-center gap-3 ml-auto">
                                <ShareButtons Url="@(Nav.BaseUri.TrimEnd('/') + "/players/" + Slug)"
                                              Title="@($"{_player!.Name} scout analizi — @{a.ScoutUsername}")" />

                                <button @onclick="() => ToggleLike(a)"
                                        disabled="@(!_isLoggedIn)"
                                        class="flex items-center gap-1.5 text-sm transition-colors @(a.IsLikedByCurrentUser ? "text-pitch-400" : "text-scout-500 hover:text-scout-300") disabled:cursor-default"
                                        title="@(_isLoggedIn ? "" : "Beğenmek için giriş yap")">
                                    <svg class="w-4 h-4" fill="@(a.IsLikedByCurrentUser ? "currentColor" : "none")"
                                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                                    </svg>
                                    @a.LikeCount
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = default!;

    private PlayerDetailVm? _player;
    private bool _loading = true;
    private string? _userVote;
    private bool _isLoggedIn;
    private bool _isAdmin;
    private Guid _userId;
    private bool _syncing;
    private bool _syncSuccess;
    private string? _syncError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _isLoggedIn = authState.User.Identity?.IsAuthenticated ?? false;

        if (_isLoggedIn)
        {
            Guid.TryParse(authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _userId);
            _isAdmin = authState.User.IsInRole("Admin");
        }

        var result = await PlayerService.GetDetailAsync(Slug, _isLoggedIn ? _userId : null);
        _player = result.Data;
        _loading = false;

        if (_player is not null && _isLoggedIn)
            _userVote = await VoteService.GetUserVoteAsync(_player.Id, _userId);
    }

    private async Task SyncFromTm()
    {
        if (_player is null || _syncing) return;

        _syncing = true;
        _syncSuccess = false;
        _syncError = null;

        var result = await PlayerService.SyncFromTransfermarktAsync(_player.Id);

        if (result.IsSuccess)
        {
            // Sayfayı taze veriyle yenile
            var fresh = await PlayerService.GetDetailAsync(Slug, _userId == Guid.Empty ? null : _userId);
            if (fresh.Data is not null) _player = fresh.Data;
            _syncSuccess = true;
        }
        else
        {
            _syncError = result.ErrorCode switch
            {
                "TRANSFERMARKT_SCRAPE_FAILED" => "Transfermarkt'tan veri çekilemedi. Lütfen daha sonra tekrar dene.",
                _ => "Sync başarısız: " + result.ErrorCode
            };
        }

        _syncing = false;
    }

    private async Task Vote(string voteType)
    {
        if (_player is null || !_isLoggedIn) return;

        await VoteService.VoteAsync(_player.Id, _userId, voteType);

        if (_userVote == voteType)
        {
            if (voteType == "Up") { _player.UpvoteCount--; _player.Score--; }
            else { _player.DownvoteCount--; _player.Score++; }
            _userVote = null;
        }
        else
        {
            if (_userVote == "Up") { _player.UpvoteCount--; _player.Score--; }
            else if (_userVote == "Down") { _player.DownvoteCount--; _player.Score++; }

            _userVote = voteType;
            if (voteType == "Up") { _player.UpvoteCount++; _player.Score++; }
            else { _player.DownvoteCount++; _player.Score--; }
        }
    }

    private async Task ToggleLike(AnalysisVm analysis)
    {
        if (!_isLoggedIn) return;

        if (analysis.IsLikedByCurrentUser)
        {
            await LikeService.UnlikeAsync(analysis.Id, _userId);
            analysis.IsLikedByCurrentUser = false;
            analysis.LikeCount--;
        }
        else
        {
            await LikeService.LikeAsync(analysis.Id, _userId);
            analysis.IsLikedByCurrentUser = true;
            analysis.LikeCount++;
        }
    }
}
