@page "/scouters/{Username}"
@inject IScoutingApiService Api
@rendermode InteractiveServer

<PageTitle>@Username — Scout</PageTitle>
<HeadContent>
    @if (_profile is not null)
    {
        <meta name="description" content="@_profile.Username scout profili. @_profile.ApprovedAnalysisCount onaylı analiz, @_profile.FollowerCount takipçi." />
    }
</HeadContent>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    @if (_profile is null && !_loading)
    {
        <div class="text-center py-24 text-scout-500">
            <p class="text-5xl mb-4">👤</p>
            <p>Scout bulunamadı</p>
        </div>
    }
    else if (_profile is null)
    {
        <div class="animate-pulse space-y-4">
            <div class="h-8 bg-scout-800 rounded w-1/4"></div>
            <div class="h-4 bg-scout-800 rounded w-1/3"></div>
        </div>
    }
    else
    {
        <!-- Profile Header -->
        <div class="card mb-8">
            <div class="flex flex-col sm:flex-row gap-6">
                <div class="w-20 h-20 rounded-full bg-pitch-950 border-2 border-pitch-800 flex items-center justify-center shrink-0">
                    @if (!string.IsNullOrEmpty(_profile.AvatarUrl))
                    {
                        <img src="@_profile.AvatarUrl" alt="@_profile.Username" class="w-20 h-20 rounded-full object-cover" />
                    }
                    else
                    {
                        <span class="font-display text-3xl text-pitch-500">@_profile.Username[0..1].ToUpper()</span>
                    }
                </div>

                <div class="flex-1">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div>
                            <h1 class="text-2xl font-bold text-white">@@@_profile.Username</h1>
                            @if (!string.IsNullOrEmpty(_profile.Bio))
                            {
                                <p class="text-scout-400 mt-1">@_profile.Bio</p>
                            }
                        </div>
                        <button @onclick="ToggleFollow"
                                class="@(_profile.IsFollowedByViewer ? "btn-secondary" : "btn-primary") text-sm">
                            @(_profile.IsFollowedByViewer ? "Takip Ediliyor" : "Takip Et")
                        </button>
                    </div>

                    <div class="flex items-center gap-6 mt-4 pt-4 border-t border-scout-800">
                        <div class="text-center">
                            <p class="text-xl font-bold text-white">@_profile.ApprovedAnalysisCount</p>
                            <p class="text-xs text-scout-500">Analiz</p>
                        </div>
                        <div class="text-center">
                            <p class="text-xl font-bold text-white">@_profile.FollowerCount</p>
                            <p class="text-xs text-scout-500">Takipçi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Analyses -->
        <div>
            <h2 class="section-title mb-6">Son Analizler</h2>

            @if (_profile.RecentAnalyses.Count == 0)
            {
                <div class="card text-center py-10 text-scout-500">
                    Henüz onaylı analiz yok.
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var analysis in _profile.RecentAnalyses)
                    {
                        <a href="/players/@analysis.PlayerSlug" class="card-hover block">
                            <div class="flex items-start gap-4">
                                <div class="w-12 h-12 rounded-lg bg-scout-800 shrink-0 overflow-hidden flex items-center justify-center">
                                    @if (!string.IsNullOrEmpty(analysis.PlayerImageUrl))
                                    {
                                        <img src="@analysis.PlayerImageUrl" alt="@analysis.PlayerName" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="text-scout-500 font-bold">@analysis.PlayerName[0]</span>
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-sm font-semibold text-white">@analysis.PlayerName</span>
                                        @if (analysis.AIScore.HasValue)
                                        {
                                            <span class="ai-score">AI @analysis.AIScore.Value.ToString("0.0")</span>
                                        }
                                    </div>
                                    <p class="text-sm text-scout-400 line-clamp-2">@analysis.ContentPreview</p>
                                    <p class="text-xs text-scout-600 mt-1">@analysis.CreatedAt.ToString("dd MMM yyyy")</p>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    }

</div>

@code {
    [Parameter] public string Username { get; set; } = default!;

    private ScouterProfile? _profile;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await Api.GetScouterProfileAsync(Username);
        _profile = result.Data;
        _loading = false;
    }

    private async Task ToggleFollow()
    {
        if (_profile is null) return;

        if (_profile.IsFollowedByViewer)
        {
            await Api.UnfollowScouterAsync(_profile.Id);
            _profile.IsFollowedByViewer = false;
            _profile.FollowerCount--;
        }
        else
        {
            await Api.FollowScouterAsync(_profile.Id);
            _profile.IsFollowedByViewer = true;
            _profile.FollowerCount++;
        }
    }
}
