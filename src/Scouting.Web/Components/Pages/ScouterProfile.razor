@page "/scouters/{Username}"
@inject IScouterService ScouterService
@inject IFileService FileService
@inject AuthenticationStateProvider AuthState
@rendermode InteractiveServer

<PageTitle>@Username — Scout</PageTitle>
<HeadContent>
    @if (_profile is not null)
    {
        <meta name="description" content="@_profile.Username scout profili. @_profile.ApprovedAnalysisCount onaylı analiz." />
    }
</HeadContent>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    @if (_loading)
    {
        <div class="animate-pulse space-y-4">
            <div class="h-8 bg-scout-800 rounded w-1/4" />
            <div class="h-4 bg-scout-800 rounded w-1/3" />
        </div>
    }
    else if (_profile is null)
    {
        <div class="text-center py-24 text-scout-500">
            <p class="text-5xl mb-4">👤</p><p>Scout bulunamadı</p>
        </div>
    }
    else
    {
        <div class="card mb-8">
            <div class="flex flex-col sm:flex-row gap-6">

                <!-- Avatar -->
                <div class="relative shrink-0 group w-20 h-20">
                    <div class="w-20 h-20 rounded-full bg-pitch-950 border-2 border-pitch-800 flex items-center justify-center overflow-hidden">
                        @if (!string.IsNullOrEmpty(_profile.AvatarUrl))
                        {
                            <img src="@_profile.AvatarUrl" alt="@_profile.Username" class="w-20 h-20 object-cover rounded-full" />
                        }
                        else
                        {
                            <span class="font-display text-3xl text-pitch-500">@_profile.Username[0..1].ToUpper()</span>
                        }
                    </div>

                    @if (_isOwner)
                    {
                        <label class="absolute inset-0 rounded-full flex items-center justify-center bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
                               title="Fotoğraf değiştir">
                            @if (_avatarUploading)
                            {
                                <span class="text-xs text-white">...</span>
                            }
                            else
                            {
                                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            }
                            <InputFile OnChange="OnAvatarSelected" accept=".jpg,.jpeg,.png,.webp" class="hidden" />
                        </label>
                    }
                </div>

                <div class="flex-1">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div>
                            <h1 class="text-2xl font-bold text-white">@@@_profile.Username</h1>
                            @if (!string.IsNullOrEmpty(_profile.Bio))
                            {
                                <p class="text-scout-400 mt-1">@_profile.Bio</p>
                            }
                            @if (!string.IsNullOrEmpty(_avatarError))
                            {
                                <p class="text-xs text-red-400 mt-1">@_avatarError</p>
                            }
                        </div>

                        <div class="flex items-center gap-2">
                            @if (_isOwner)
                            {
                                <a href="/analysis/new" class="btn-primary text-sm">+ Analiz Yaz</a>
                            }
                            else if (_isLoggedIn)
                            {
                                <button @onclick="ToggleFollow"
                                        class="@(_profile.IsFollowedByViewer ? "btn-secondary" : "btn-primary") text-sm">
                                    @(_profile.IsFollowedByViewer ? "Takip Ediliyor" : "Takip Et")
                                </button>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-6 mt-4 pt-4 border-t border-scout-800">
                        <div class="text-center">
                            <p class="text-xl font-bold text-white">@_profile.ApprovedAnalysisCount</p>
                            <p class="text-xs text-scout-500">Analiz</p>
                        </div>
                        <div class="text-center">
                            <p class="text-xl font-bold text-white">@_profile.FollowerCount</p>
                            <p class="text-xs text-scout-500">Takipçi</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progress bar — sadece profil sahibine görünür -->
        @if (_isOwner)
        {
            @{
                var pts      = _profile.TotalPoints;
                var level    = _profile.Level;
                var next     = level.NextThreshold();
                var prev     = level.PrevThreshold();
                var isExpert = level == UserLevel.Expert;
                var pct      = isExpert ? 100
                               : (int)Math.Min(100, (pts - prev) * 100.0 / (next - prev));
            }
            <div class="card mb-8">
                <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-3">
                        <span class="@level.BadgeClass()">@level.DisplayName()</span>
                        <span class="text-2xl font-bold text-white">@pts puan</span>
                    </div>
                    @if (!isExpert)
                    {
                        <span class="text-xs text-scout-500">
                            <span class="text-white font-semibold">@(next - pts)</span> puan daha → @level.NextLevelName()
                        </span>
                    }
                    else
                    {
                        <span class="text-xs text-yellow-400 font-semibold">✦ Expert — Kazanç aktif</span>
                    }
                </div>

                <!-- Progress bar -->
                <div class="w-full bg-scout-800 rounded-full h-2 mb-3 overflow-hidden">
                    <div class="h-2 rounded-full transition-all duration-500 @(isExpert ? "bg-yellow-500" : "bg-pitch-500")"
                         style="width: @pct%"></div>
                </div>

                <!-- Breakdown -->
                <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-xs text-scout-600">
                    <span>
                        <span class="text-scout-400">@_profile.ApprovedAnalysisCount</span> analiz
                        × 5 = <span class="text-white">@(_profile.ApprovedAnalysisCount * 5)p</span>
                    </span>
                    <span>
                        <span class="text-scout-400">@_profile.TotalLikesReceived</span> beğeni
                        × 1 = <span class="text-white">@_profile.TotalLikesReceived p</span>
                    </span>
                    @if (_profile.BonusPoints > 0)
                    {
                        <span>
                            Bonus = <span class="text-pitch-400 font-semibold">+@_profile.BonusPoints p</span>
                        </span>
                    }
                    <a href="/how-it-works" class="ml-auto text-scout-700 hover:text-scout-400 transition-colors">
                        Nasıl çalışır? ↗
                    </a>
                </div>
            </div>
        }

        <h2 class="section-title mb-6">Son Analizler</h2>

        @if (_profile.RecentAnalyses.Count == 0)
        {
            <div class="card text-center py-10 text-scout-500">Henüz onaylı analiz yok.</div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var a in _profile.RecentAnalyses)
                {
                    <a href="/players/@a.PlayerSlug" class="card-hover block">
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-lg bg-scout-800 shrink-0 flex items-center justify-center overflow-hidden">
                                @if (!string.IsNullOrEmpty(a.PlayerImageUrl))
                                {
                                    <img src="@a.PlayerImageUrl" alt="@a.PlayerName" class="w-12 h-12 object-cover rounded-lg" />
                                }
                                else
                                {
                                    <span class="text-scout-500 font-bold">@a.PlayerName[0]</span>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-semibold text-white">@a.PlayerName</span>
                                    @if (a.AIScore.HasValue)
                                    {
                                        <span class="ai-score">AI @a.AIScore.Value.ToString("0.0")</span>
                                    }
                                </div>
                                <p class="text-sm text-scout-400 line-clamp-2">@a.ContentPreview</p>
                                <p class="text-xs text-scout-600 mt-1">@a.CreatedAt.ToString("dd MMM yyyy")</p>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Username { get; set; } = default!;

    private ScouterProfileVm? _profile;
    private bool _loading = true;
    private bool _isLoggedIn;
    private bool _isOwner;
    private Guid _userId;
    private bool _avatarUploading;
    private string? _avatarError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _isLoggedIn = auth.User.Identity?.IsAuthenticated ?? false;
        if (_isLoggedIn)
        {
            Guid.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _userId);
            var currentUsername = auth.User.FindFirst(ClaimTypes.Name)?.Value;
            _isOwner = string.Equals(currentUsername, Username, StringComparison.OrdinalIgnoreCase);
        }

        var result = await ScouterService.GetProfileAsync(Username, _isLoggedIn ? _userId : null);
        _profile = result.Data;
        _loading = false;
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _avatarError = null;
        _avatarUploading = true;

        var uploadResult = await FileService.UploadAvatarAsync(e.File);
        if (!uploadResult.IsSuccess)
        {
            _avatarError = uploadResult.ErrorCode switch
            {
                "FILE_INVALID_TYPE" => "Sadece JPG, PNG ve WebP kabul edilir.",
                "FILE_TOO_LARGE"    => "Dosya 5 MB'ı geçemez.",
                _                  => "Yükleme başarısız."
            };
            _avatarUploading = false;
            return;
        }

        await ScouterService.UpdateAvatarAsync(_userId, uploadResult.Data!);
        _profile!.AvatarUrl = uploadResult.Data;
        _avatarUploading = false;
    }

    private async Task ToggleFollow()
    {
        if (_profile is null || !_isLoggedIn) return;

        if (_profile.IsFollowedByViewer)
        {
            await ScouterService.UnfollowAsync(_userId, _profile.Id);
            _profile.IsFollowedByViewer = false;
            _profile.FollowerCount--;
        }
        else
        {
            await ScouterService.FollowAsync(_userId, _profile.Id);
            _profile.IsFollowedByViewer = true;
            _profile.FollowerCount++;
        }
    }
}
