@page "/analizlerim"
@inject IAnalysisService AnalysisService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Analizlerim</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center justify-between mb-8">
        <h1 class="section-title">Analizlerim</h1>
        <a href="/analysis/new" class="btn-primary text-sm">+ Yeni Analiz</a>
    </div>

    @if (_loading)
    {
        <div class="animate-pulse space-y-4">
            @for (var i = 0; i < 5; i++)
            {
                <div class="h-24 bg-scout-800 rounded-xl" />
            }
        </div>
    }
    else if (_analyses.Count == 0)
    {
        <div class="card text-center py-16">
            <p class="text-4xl mb-3">📋</p>
            <p class="font-medium text-scout-300">Henüz analiz yazmadınız</p>
            <p class="text-sm text-scout-500 mt-1">Oyuncu sayfalarından analiz yazabilir veya yeni bir oyuncu önerebilirsiniz.</p>
            <div class="flex justify-center gap-3 mt-5">
                <a href="/analysis/new" class="btn-primary text-sm">+ Analiz Yaz</a>
                <a href="/suggest" class="btn-secondary text-sm">+ Oyuncu Öner</a>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var a in _analyses)
            {
                <div class="card">
                    <div class="flex items-start gap-4">
                        <!-- Player image -->
                        <div class="w-12 h-12 rounded-lg bg-scout-800 shrink-0 overflow-hidden flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(a.PlayerImageUrl))
                            {
                                <img src="@a.PlayerImageUrl" alt="@a.PlayerName" class="w-12 h-12 object-cover" />
                            }
                            else
                            {
                                <span class="text-scout-500 font-bold text-lg">@a.PlayerName[0]</span>
                            }
                        </div>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2 mb-1">
                                <a href="/players/@a.PlayerSlug"
                                   class="font-semibold text-white hover:text-pitch-400 transition-colors">
                                    @a.PlayerName
                                </a>
                                <div class="flex items-center gap-2 shrink-0">
                                    @if (a.AIScore.HasValue)
                                    {
                                        <span class="ai-score">AI @a.AIScore.Value.ToString("0.0")</span>
                                    }
                                    <span class="badge @StatusBadgeClass(a.Status)">
                                        @StatusLabel(a.Status)
                                    </span>
                                </div>
                            </div>

                            <p class="text-sm text-scout-400 line-clamp-2">@a.ContentPreview</p>

                            <div class="flex items-center gap-4 mt-2 text-xs text-scout-600">
                                <span>@a.CreatedAt.ToString("dd MMM yyyy")</span>
                                @if (a.LikeCount > 0)
                                {
                                    <span class="flex items-center gap-1 text-pitch-400">
                                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
                                        </svg>
                                        @a.LikeCount beğeni
                                    </span>
                                }
                                @if (a.IsFlaggedAsDuplicate)
                                {
                                    <span class="text-yellow-500 flex items-center gap-1">
                                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                                        </svg>
                                        Tekrar olabilir
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(a.AISummary))
                    {
                        <div class="mt-3 pt-3 border-t border-scout-800">
                            <p class="text-xs text-scout-500 italic leading-relaxed">@a.AISummary</p>
                        </div>
                    }
                </div>
            }
        </div>

        @if (_hasMore)
        {
            <div class="text-center mt-8">
                <button @onclick="LoadMore" disabled="@_loadingMore" class="btn-secondary">
                    @if (_loadingMore)
                    {
                        <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                        </svg>
                        <span>Yükleniyor...</span>
                    }
                    else
                    {
                        <span>Daha Fazla Göster</span>
                    }
                </button>
            </div>
        }
    }
</div>

@code {
    private List<MyAnalysisVm> _analyses = [];
    private bool _loading = true;
    private bool _loadingMore;
    private bool _hasMore;
    private int _page = 1;
    private const int PageSize = 10;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (!(auth.User.Identity?.IsAuthenticated ?? false))
        {
            Nav.NavigateTo("/login");
            return;
        }

        Guid.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out _userId);
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        var result = await AnalysisService.GetMyAnalysesAsync(_userId, _page, PageSize);
        _analyses.AddRange(result.Data ?? []);
        _hasMore = (result.Data?.Count ?? 0) == PageSize;
    }

    private async Task LoadMore()
    {
        _loadingMore = true;
        _page++;
        await LoadAsync();
        _loadingMore = false;
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Approved" => "badge-approved",
        "Rejected" => "badge-rejected",
        _ => "badge-pending"
    };

    private static string StatusLabel(string status) => status switch
    {
        "Approved" => "Onaylı",
        "Rejected" => "Reddedildi",
        _ => "Beklemede"
    };
}
