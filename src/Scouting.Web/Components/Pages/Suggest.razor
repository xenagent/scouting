@page "/suggest"
@attribute [Authorize]
@inject IPlayerService PlayerService
@inject IFileService FileService
@inject AuthenticationStateProvider AuthState
@rendermode InteractiveServer

<PageTitle>Oyuncu Öner — Scout</PageTitle>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="font-display text-4xl text-white mb-2">OYUNCU ÖNER</h1>
        <p class="text-scout-400">Kaliteli analiz ekle. Admin inceledikten sonra yayına alınır.</p>
    </div>

    @if (_submitted)
    {
        <div class="card border-pitch-800 bg-pitch-950/30 text-center py-10">
            <div class="text-4xl mb-4">✓</div>
            <h2 class="text-xl font-bold text-white mb-2">Önerin alındı!</h2>
            <p class="text-scout-400 mb-6">Admin incelemesinden sonra yayına alınacak.</p>
            <div class="flex justify-center gap-3">
                <a href="/players" class="btn-secondary">Oyunculara Dön</a>
                <button @onclick="Reset" class="btn-primary">Yeni Öneri Ekle</button>
            </div>
        </div>
    }
    else
    {
        <div class="space-y-6">
            <div class="card">
                <h3 class="text-sm font-semibold text-scout-300 uppercase tracking-wider mb-4">Oyuncu Bilgileri</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="sm:col-span-2">
                        <label class="label">Oyuncu Adı *</label>
                        <input @bind="_input.Name" type="text" placeholder="Arda Güler" class="input" />
                    </div>
                    <div>
                        <label class="label">Yaş *</label>
                        <input @bind="_input.Age" type="number" min="13" max="50" class="input" />
                    </div>
                    <div>
                        <label class="label">Pozisyon *</label>
                        <select @bind="_input.Position" class="input">
                            <option value="">Seçiniz</option>
                            <option value="GK">GK - Kaleci</option>
                            <option value="CB">CB - Stoper</option>
                            <option value="LB">LB - Sol Bek</option>
                            <option value="RB">RB - Sağ Bek</option>
                            <option value="CDM">CDM - Def. Orta</option>
                            <option value="CM">CM - Merkez</option>
                            <option value="CAM">CAM - Of. Orta</option>
                            <option value="LM">LM - Sol Orta</option>
                            <option value="RM">RM - Sağ Orta</option>
                            <option value="LW">LW - Sol Kanat</option>
                            <option value="RW">RW - Sağ Kanat</option>
                            <option value="ST">ST - Santrafor</option>
                            <option value="CF">CF - İkinci Forvet</option>
                        </select>
                    </div>
                    <div>
                        <label class="label">Takım *</label>
                        <input @bind="_input.Team" type="text" placeholder="Real Madrid B" class="input" />
                    </div>
                    <div>
                        <label class="label">Lig *</label>
                        <input @bind="_input.League" type="text" placeholder="Süper Lig" class="input" />
                    </div>
                    <div>
                        <label class="label">Ülke *</label>
                        <input @bind="_input.Country" type="text" placeholder="Türkiye" class="input" />
                    </div>

                    <!-- Image upload -->
                    <div class="sm:col-span-2">
                        <label class="label">Oyuncu Fotoğrafı <span class="text-scout-600">(opsiyonel)</span></label>

                        @if (!string.IsNullOrEmpty(_input.ImageUrl))
                        {
                            <div class="flex items-center gap-3 mb-3">
                                <img src="@_input.ImageUrl" alt="Önizleme"
                                     class="w-16 h-16 rounded-lg object-cover border border-scout-700" />
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs text-pitch-400 truncate">@_input.ImageUrl</p>
                                </div>
                                <button type="button" @onclick="ClearImage"
                                        class="text-xs text-red-400 hover:text-red-300">Kaldır</button>
                            </div>
                        }

                        <div class="flex gap-2">
                            <label class="flex-1 flex items-center justify-center gap-2 border border-dashed border-scout-700 rounded-lg p-3 cursor-pointer hover:border-pitch-600 transition-colors @(_uploading ? "opacity-50 pointer-events-none" : "")">
                                @if (_uploading)
                                {
                                    <span class="text-sm text-scout-400">Yükleniyor...</span>
                                }
                                else
                                {
                                    <svg class="w-4 h-4 text-scout-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                    <span class="text-sm text-scout-400">Dosya seç (JPG, PNG, WebP · max 5 MB)</span>
                                }
                                <InputFile OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp" class="hidden" />
                            </label>
                        </div>

                        @if (!string.IsNullOrEmpty(_uploadError))
                        {
                            <p class="text-xs text-red-400 mt-1">@_uploadError</p>
                        }
                    </div>
                </div>
            </div>

            <div class="card">
                <h3 class="text-sm font-semibold text-scout-300 uppercase tracking-wider mb-4">Analiz</h3>
                <div class="space-y-4">
                    <div>
                        <label class="label">Video Linki *</label>
                        <input @bind="_input.VideoUrl" type="url" placeholder="https://youtube.com/..." class="input" />
                    </div>
                    <div>
                        <label class="label">Analiz Yazısı * <span class="text-scout-600 font-normal">(min. 50 karakter)</span></label>
                        <textarea @bind="_input.AnalysisContent" rows="8"
                                  placeholder="Oyuncunun teknik özellikleri, güçlü/zayıf yanları..."
                                  class="input resize-none"></textarea>
                        <div class="flex justify-between mt-1">
                            <p class="text-xs text-scout-600">50–5000 karakter</p>
                            <span class="text-xs @((_input.AnalysisContent?.Length ?? 0) < 50 ? "text-red-500" : "text-pitch-500")">
                                @(_input.AnalysisContent?.Length ?? 0)/5000
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="rounded-lg bg-red-950 border border-red-800 p-4 text-sm text-red-300">@_error</div>
            }

            <div class="flex justify-end gap-3">
                <a href="/players" class="btn-secondary">İptal</a>
                <button @onclick="Submit" disabled="@(_submitting || _uploading)" class="btn-primary">
                    @(_submitting ? "Gönderiliyor..." : "Öneri Gönder")
                </button>
            </div>
        </div>
    }
</div>

@code {
    private SuggestPlayerInput _input = new();
    private bool _submitting;
    private bool _submitted;
    private bool _uploading;
    private string? _error;
    private string? _uploadError;
    private Guid _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var idClaim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        Guid.TryParse(idClaim, out _userId);
    }

    private async Task OnImageSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        _uploading = true;

        var result = await FileService.UploadPlayerImageAsync(e.File);
        _uploading = false;

        if (result.IsSuccess)
            _input.ImageUrl = result.Data;
        else
            _uploadError = result.ErrorCode switch
            {
                "FILE_INVALID_TYPE" => "Sadece JPG, PNG ve WebP dosyaları kabul edilir.",
                "FILE_TOO_LARGE"    => "Dosya boyutu 5 MB'ı geçemez.",
                _                  => "Yükleme başarısız oldu."
            };
    }

    private void ClearImage() => _input.ImageUrl = null;

    private async Task Submit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_input.Name) || _input.Age == 0 ||
            string.IsNullOrWhiteSpace(_input.Position) || string.IsNullOrWhiteSpace(_input.Team) ||
            string.IsNullOrWhiteSpace(_input.League) || string.IsNullOrWhiteSpace(_input.Country) ||
            string.IsNullOrWhiteSpace(_input.VideoUrl) || string.IsNullOrWhiteSpace(_input.AnalysisContent))
        {
            _error = "Lütfen tüm zorunlu alanları doldurun.";
            return;
        }

        if (_input.AnalysisContent.Length < 50)
        {
            _error = "Analiz yazısı en az 50 karakter olmalıdır.";
            return;
        }

        _submitting = true;
        var result = await PlayerService.SuggestAsync(_input, _userId);
        _submitting = false;

        if (result.IsSuccess)
            _submitted = true;
        else
            _error = result.ErrorCode switch
            {
                ErrorCodes.ANALYSIS_CONTENT_TOO_SHORT => "Analiz çok kısa.",
                _ => "Bir hata oluştu: " + result.ErrorCode
            };
    }

    private void Reset()
    {
        _input = new();
        _submitted = false;
        _error = null;
        _uploadError = null;
    }
}
